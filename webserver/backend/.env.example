# Port where the web server listens (accessible from phone on LAN)
PORT=3001

# Upstash Redis URL
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379

# Local LMU API — don't change unless LMU changes its port
LMU_URL=http://localhost:6397

# Session TTL in seconds (1h by default)
TTL_SECONDS=3600
